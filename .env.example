# =============================================================================
# Neo Paylater — salin file ini ke `.env` lalu isi nilai yang relevan.
# Di server production: APP_DEBUG=false, APP_ENV=production, APP_URL=https://...
# =============================================================================

APP_NAME="Neo Paylater"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Production HTTPS: set APP_URL=https://domain-kamu (bukan http). Opsional jika URL masih http tapi situs di HTTPS:
# APP_FORCE_HTTPS=true

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database — default SQLite (file di database/database.sqlite).
# Untuk MySQL/PostgreSQL, ubah DB_CONNECTION dan sesuaikan host/database/user.
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=neopaylater
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=public
# URL disk public (preview upload Livewire, avatar). Default relatif `/storage` — aman bila APP_URL belum https.
# Hanya override jika perlu URL absolut/CDN, mis. FILESYSTEM_PUBLIC_URL=https://domain-kamu/storage
# FILESYSTEM_PUBLIC_URL=/storage
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Gemini — opsional; tanpa key, bill manual tetap jalan, import AI struk gagal jelas.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
